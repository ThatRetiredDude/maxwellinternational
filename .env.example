# Copy to `.env` (gitignored). Used by Wrangler for non-interactive deploy.
# Create token: https://dash.cloudflare.com/profile/api-tokens → Create Token → Custom token
# User token permissions:
#   Account → Cloudflare Pages → Edit
#   All users → Memberships → Read
#
# Account-owned tokens (often start with cfat_) cannot discover accounts through
# /memberships. Add CLOUDFLARE_ACCOUNT_ID for those tokens.
# Find it in Cloudflare Dashboard → Workers & Pages → Overview/right sidebar,
# or Dashboard → your account → Account ID.
#
# Paste only token strings; do not include a "Bearer " prefix.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
