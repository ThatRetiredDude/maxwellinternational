# Copy to `.env` (gitignored). Used by Wrangler for non-interactive deploy.
# Create token: https://dash.cloudflare.com/profile/api-tokens → Create Token → Custom token
# Permissions (minimum):
#   Account → Cloudflare Pages → Edit
#   Account → Workers Scripts → Edit
# Account resources: include your Cloudflare account (or All accounts).
CLOUDFLARE_API_TOKEN=
