---
// Maxwell International placeholder landing page for GitHub Pages.
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content="Maxwell International — website under construction." />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<title>Maxwell International</title>
		<style>
			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}
			html {
				font-family:
					system-ui,
					-apple-system,
					"Segoe UI",
					Roboto,
					"Helvetica Neue",
					Arial,
					sans-serif;
				line-height: 1.5;
				-webkit-font-smoothing: antialiased;
			}
			body {
				margin: 0;
				min-height: 100svh;
				display: grid;
				place-items: center;
				padding: 2rem;
				background: #0f1419;
				color: #e8eaed;
			}
			main {
				text-align: center;
				max-width: min(56rem, 100%);
				margin-inline: auto;
			}
			.hero {
				margin: 0 0 1.75rem;
			}
			.hero img {
				display: block;
				width: 100%;
				max-height: min(48vh, 520px);
				height: auto;
				object-fit: contain;
				margin-inline: auto;
				border-radius: 10px;
				box-shadow: 0 24px 48px rgba(0, 0, 0, 0.45);
			}
			h1 {
				margin: 0 0 0.75rem;
				font-size: clamp(1.5rem, 4vw, 2rem);
				font-weight: 600;
				letter-spacing: -0.02em;
			}
			p {
				margin: 0;
				font-size: 1.125rem;
				color: #9aa0a6;
			}
		</style>
	</head>
	<body>
		<main>
			<figure class="hero">
				<img
					src={`${import.meta.env.BASE_URL}hero.png`}
					alt="Maxwell International"
					width="1023"
					height="575"
					loading="eager"
					decoding="async"
				/>
			</figure>
			<h1>Maxwell International</h1>
			<p>This site is under construction.</p>
		</main>
	</body>
</html>
